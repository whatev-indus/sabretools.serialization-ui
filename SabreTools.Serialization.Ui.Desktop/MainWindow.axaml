<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="using:SabreTools.Serialization.Ui.Desktop.ViewModels"
        mc:Ignorable="d"
        x:Class="SabreTools.Serialization.Ui.Desktop.MainWindow"
        x:DataType="viewModels:MainWindowViewModel"
        Width="1360"
        Height="900"
        MinWidth="1100"
        MinHeight="720"
        Icon="avares://SabreTools.Serialization.Ui.Desktop/Assets/Icons/AppIcon.png"
        Title="SabreTools.Serialization GUI">
  <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto">
    <Grid Margin="24">
      <Grid ColumnDefinitions="320,*">
        <StackPanel Grid.Column="0" Spacing="18" Margin="0,0,18,0">
          <Image Source="avares://SabreTools.Serialization.Ui.Desktop/Assets/SabreTools.Serialization_Logo.png"
                 Height="44"
                 HorizontalAlignment="Left"
                 Stretch="Uniform"
                 Margin="0,0,0,4" />

          <Border Classes="card">
            <StackPanel Spacing="14">
              <TextBlock Classes="section-title" Text="Open File" />

              <Grid ColumnDefinitions="*,*">
                <Button Grid.Column="0" Classes="secondary" Content="Browse File" Click="BrowseFileButton_OnClick" Margin="0,0,5,0" />
                <Button Grid.Column="1" Classes="primary" Content="Inspect File" Click="InspectButton_OnClick" IsEnabled="{Binding CanInspect}" />
              </Grid>

              <CheckBox Content="Include debug output when extracting." IsChecked="{Binding IncludeDebug}" />
            </StackPanel>
          </Border>

          <Border Classes="card">
            <StackPanel Spacing="14">
              <TextBlock Classes="section-title" Text="Extract Contents" />

              <Grid ColumnDefinitions="*,*">
                <Button Grid.Column="0" Classes="secondary" Content="Browse Folder" Click="BrowseFolderButton_OnClick" Margin="0,0,5,0" />
                <Button Grid.Column="1" Classes="primary" Content="Extract All" Click="ExtractButton_OnClick" IsEnabled="{Binding CanExtract}" />
              </Grid>
            </StackPanel>
          </Border>

          <Border Classes="card">
            <StackPanel Spacing="12">
              <TextBlock Classes="section-title" Text="Detection Summary" />

              <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                <TextBlock Grid.Row="0" Classes="caption" Text="Wrapper type" />
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding WrapperType}" TextWrapping="Wrap" Margin="12,0,0,8" />

                <TextBlock Grid.Row="1" Classes="caption" Text="Description" Margin="0,0,0,8" />
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Description}" TextWrapping="Wrap" Margin="12,0,0,8" />

                <TextBlock Grid.Row="2" Classes="caption" Text="Printable" Margin="0,0,0,8" />
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding PrintableState}" Margin="12,0,0,8" />

                <TextBlock Grid.Row="3" Classes="caption" Text="Extractable" Margin="0,0,0,8" />
                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding ExtractableState}" Margin="12,0,0,8" />

                <TextBlock Grid.Row="4" Classes="caption" Text="Error" />
                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding ErrorMessage}" TextWrapping="Wrap" Margin="12,0,0,0" />
              </Grid>
            </StackPanel>
          </Border>

          <Border Classes="card">
            <StackPanel Spacing="12">
              <TextBlock Classes="section-title" Text="Current Status" />
              <TextBlock Text="{Binding StatusMessage}" FontWeight="SemiBold" TextWrapping="Wrap" />
              <TextBlock Classes="caption" Text="{Binding BusyState}" />
            </StackPanel>
          </Border>
        </StackPanel>

        <Border Grid.Column="1" Classes="card" Padding="0" MinHeight="520">
          <TabControl Classes="workspace-tabs">
            <TabItem Header="JSON Tree">
              <Grid Margin="12">
                <Border
                        Background="#101722"
                        BorderBrush="#28374E"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="12">
                  <ScrollViewer>
                    <TreeView ItemsSource="{Binding JsonTreeItems}">
                      <TreeView.ItemTemplate>
                        <TreeDataTemplate ItemsSource="{Binding Children}">
                          <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Summary}" Foreground="#8CA0BB" />
                          </StackPanel>
                        </TreeDataTemplate>
                      </TreeView.ItemTemplate>
                    </TreeView>
                  </ScrollViewer>
                </Border>
              </Grid>
            </TabItem>

            <TabItem Header="Printed Info">
              <Grid Margin="12">
                <Border Background="#101722"
                        BorderBrush="#28374E"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="12">
                  <TextBox AcceptsReturn="True"
                           IsReadOnly="True"
                           Text="{Binding PrintableOutput}"
                           TextWrapping="Wrap"
                           Background="Transparent"
                           BorderThickness="0" />
                </Border>
              </Grid>
            </TabItem>

            <TabItem Header="Raw JSON">
              <Grid Margin="12">
                <Border Background="#101722"
                        BorderBrush="#28374E"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="12">
                  <TextBox AcceptsReturn="True"
                           IsReadOnly="True"
                           Text="{Binding JsonOutput}"
                           TextWrapping="NoWrap"
                           Background="Transparent"
                           BorderThickness="0" />
                </Border>
              </Grid>
            </TabItem>
          </TabControl>
        </Border>
      </Grid>
    </Grid>
  </ScrollViewer>
</Window>
