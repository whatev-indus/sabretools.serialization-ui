<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="SabreTools.Serialization.UI.Desktop.App"
             RequestedThemeVariant="Dark">
  <Application.Styles>
    <FluentTheme />

    <Style Selector="Window">
      <Setter Property="Background" Value="#0D1119" />
      <Setter Property="Foreground" Value="#F5F7FB" />
      <Setter Property="FontFamily" Value="avares://Avalonia.Fonts.Inter#Inter" />
    </Style>

    <Style Selector="Border.card">
      <Setter Property="Background" Value="#171D29" />
      <Setter Property="BorderBrush" Value="#273245" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="18" />
      <Setter Property="Padding" Value="18" />
    </Style>

    <Style Selector="TextBlock.eyebrow">
      <Setter Property="Foreground" Value="#7BD9C6" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="TextBlock.section-title">
      <Setter Property="FontSize" Value="18" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="TextAlignment" Value="Center" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <Style Selector="TextBlock.caption">
      <Setter Property="Foreground" Value="#93A2B8" />
      <Setter Property="FontSize" Value="13" />
    </Style>

    <Style Selector="Button.primary">
      <Setter Property="Background" Value="#7BD9C6" />
      <Setter Property="Foreground" Value="#08111B" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="CornerRadius" Value="999" />
      <Setter Property="Padding" Value="18,10" />
    </Style>

    <Style Selector="Button.secondary">
      <Setter Property="Background" Value="#253146" />
      <Setter Property="Foreground" Value="#F5F7FB" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="CornerRadius" Value="999" />
      <Setter Property="Padding" Value="18,10" />
    </Style>

    <Style Selector="TextBox.path-box">
      <Setter Property="Background" Value="#111722" />
      <Setter Property="BorderBrush" Value="#2B3950" />
      <Setter Property="CornerRadius" Value="12" />
    </Style>

    <Style Selector="TabControl.workspace-tabs">
      <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style Selector="TabControl.workspace-tabs > TabStrip">
      <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.tab-header">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="0" />
      <Setter Property="Foreground" Value="#F5F7FB" />
      <Setter Property="FontSize" Value="18" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Padding" Value="14,10,14,8" />
    </Style>

    <Style Selector="TabItem">
      <Setter Property="FontSize" Value="18" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="Theme">
        <ControlTheme TargetType="TabItem">
          <Setter Property="Template">
            <ControlTemplate>
              <Border BorderBrush="Transparent"
                      BorderThickness="0,0,0,2"
                      Padding="14,10,14,8">
                <ContentPresenter Content="{TemplateBinding Header}"
                                  HorizontalAlignment="Stretch"
                                  HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                  VerticalAlignment="Center" />
              </Border>
            </ControlTemplate>
          </Setter>
        </ControlTheme>
      </Setter>
    </Style>

    <Style Selector="TabItem:selected /template/ Border">
      <Setter Property="BorderBrush" Value="#2B94B4" />
    </Style>
  </Application.Styles>
</Application>
