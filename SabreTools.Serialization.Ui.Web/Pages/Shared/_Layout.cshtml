<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SabreTools.Serialization UI</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SabreTools.Serialization.Ui.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">
        <header class="topbar">
            <div class="container topbar-inner">
                <a class="brand-mark" asp-area="" asp-page="/Index">
                    <span class="brand-badge">ST</span>
                    <span>
                        <strong>SabreTools.Serialization UI</strong>
                        <small>Wrapper-based file inspection</small>
                    </span>
                </a>
            </div>
        </header>

        <main class="container page-body" role="main">
            @RenderBody()
        </main>

        <footer class="footer-strip">
            <div class="container">
                <span>Built on ASP.NET Core with the upstream <code>SabreTools.Serialization</code> package.</span>
            </div>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
