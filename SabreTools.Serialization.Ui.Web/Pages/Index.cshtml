@page
@model IndexModel
@{
    ViewData["Title"] = "Inspector";
}

<section class="hero-panel">
    <div class="hero-copy">
        <p class="eyebrow">SabreTools.Serialization UI</p>
        <h1>Inspect binary formats with the upstream library, not a mock.</h1>
        <p class="hero-lead">
            This starter repo imports <code>SabreTools.Serialization</code> and runs the same wrapper-driven
            detection flow used by the upstream <code>InfoPrint</code> tool.
        </p>
        <div class="capability-grid">
            @foreach (var capability in Model.SampleCapabilities)
            {
                <div class="capability-card">@capability</div>
            }
        </div>
    </div>
</section>

<section class="workspace-grid">
    <div class="workspace-panel">
        <div class="panel-heading">
            <h2>Analyze a file</h2>
            <p>Upload a supported file and SabreTools will detect the wrapper type, print readable details, and emit JSON.</p>
        </div>

        <form method="post" enctype="multipart/form-data" class="upload-form">
            <label asp-for="Upload" class="upload-zone">
                <span class="upload-title">Drop a file here or click to browse</span>
                <span class="upload-subtitle">Great for archives, executables, disc images, and cartridge formats.</span>
                <input asp-for="Upload" type="file" class="upload-input" />
            </label>
            <span asp-validation-for="Upload" class="text-danger"></span>

            <button type="submit" class="analyze-button">Inspect with SabreTools</button>
        </form>
    </div>

    <div class="workspace-panel result-panel">
        <div class="panel-heading">
            <h2>Result</h2>
            <p>The output below comes from the imported library when a printable wrapper is available.</p>
        </div>

        @if (Model.Result is null)
        {
            <div class="empty-state">
                <p>No file analyzed yet.</p>
                <p>The first successful run will show the detected wrapper plus text and JSON output from SabreTools.</p>
            </div>
        }
        else
        {
            <div class="result-meta">
                <div>
                    <span class="meta-label">File</span>
                    <strong>@Model.Result.FileName</strong>
                </div>
                <div>
                    <span class="meta-label">Wrapper</span>
                    <strong>@Model.Result.WrapperType</strong>
                </div>
                <div>
                    <span class="meta-label">Printable</span>
                    <strong>@(Model.Result.IsPrintable ? "Yes" : "No")</strong>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.Result.ErrorMessage))
            {
                <div class="result-error">@Model.Result.ErrorMessage</div>
            }

            @if (!string.IsNullOrWhiteSpace(Model.Result.TextOutput))
            {
                <div class="output-block">
                    <h3>Printed Information</h3>
                    <pre>@Model.Result.TextOutput</pre>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(Model.Result.JsonOutput))
            {
                <div class="output-block">
                    <h3>JSON Export</h3>
                    <pre>@Model.Result.JsonOutput</pre>
                </div>
            }
        }
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
